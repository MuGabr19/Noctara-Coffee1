<div class="toast" id="toast"></div>

<script>
const cur=document.getElementById('cur'),curR=document.getElementById('cur-r');
let mx=0,my=0,rx=window.innerWidth/2,ry=window.innerHeight/2;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function loop(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;curR.style.left=rx+'px';curR.style.top=ry+'px';requestAnimationFrame(loop);})();

window.addEventListener('scroll',()=>{document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>60);});

let menuOpen=false;
function toggleMobile(){menuOpen=!menuOpen;document.getElementById('mobileMenu').classList.toggle('open',menuOpen);}
function closeMobile(){menuOpen=false;document.getElementById('mobileMenu').classList.remove('open');}

let lang='en';
function toggleLang(){
  lang=lang==='en'?'ar':'en';
  document.getElementById('langBtn').textContent=lang==='en'?'عربي':'EN';
  document.documentElement.setAttribute('lang',lang);
  document.body.classList.toggle('ar',lang==='ar');
  document.querySelectorAll('[data-en]').forEach(el=>{
    const txt=lang==='ar'?el.getAttribute('data-ar'):el.getAttribute('data-en');
    if(!txt)return;
    if(el.tagName==='INPUT'||el.tagName==='BUTTON'||el.tagName==='A'){el.textContent=txt;}
    else{el.innerHTML=txt;}
  });
}

function scrollToOrder(){document.getElementById('order').scrollIntoView({behavior:'smooth'});}

function orderProduct(name){
  const msg=encodeURIComponent('Hello NOCTARA! I would like to order: '+name+'\n\nPlease share delivery details.');
  window.open('https://wa.me/201551290097?text='+msg,'_blank');
  showToast(lang==='ar'?'جاري فتح واتساب...':'Opening WhatsApp...');
}

function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('on');obs.unobserve(e.target);}});},{threshold:.08});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

const track=document.getElementById('marqueeTrack');
track.innerHTML+=track.innerHTML;
</script>
