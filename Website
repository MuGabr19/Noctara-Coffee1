
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>NOCTARA Coffee | متجر القهوة المتخصصة</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: #0a0908;
            color: #ede4d3;
            scroll-behavior: smooth;
        }

        /* Custom Cursor */
        #custom-cursor {
            position: fixed;
            width: 6px;
            height: 6px;
            background: #d4af37;
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%, -50%);
            transition: width 0.2s, height 0.2s;
        }
        #cursor-dot {
            position: fixed;
            width: 28px;
            height: 28px;
            border: 1px solid rgba(212, 175, 55, 0.4);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9998;
            transform: translate(-50%, -50%);
            transition: all 0.2s ease;
        }
        a:hover ~ #custom-cursor, button:hover ~ #custom-cursor {
            width: 12px;
            height: 12px;
            background: #e8cc6a;
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 3px; }
        ::-webkit-scrollbar-track { background: #0a0908; }
        ::-webkit-scrollbar-thumb { background: #8a7020; }

        /* Header / Nav */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 20px 48px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.4s ease;
            background: transparent;
        }
        .navbar.scrolled {
            background: rgba(10, 9, 8, 0.95);
            backdrop-filter: blur(12px);
            padding: 12px 48px;
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }
        .logo-img {
            height: 45px;
            width: auto;
            filter: brightness(0.95);
            transition: filter 0.3s;
        }
        .logo-img:hover {
            filter: brightness(1.1);
        }
        .logo-text {
            font-size: 1.4rem;
            font-weight: 500;
            letter-spacing: 2px;
            color: #f8f3ea;
        }
        .logo-text span {
            color: #d4af37;
        }
        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }
        .nav-links a {
            color: #a8967a;
            text-decoration: none;
            font-size: 0.85rem;
            letter-spacing: 1px;
            transition: color 0.3s;
        }
        .nav-links a:hover {
            color: #d4af37;
        }
        .cart-icon {
            position: relative;
            cursor: pointer;
            background: none;
            border: none;
            color: #ede4d3;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .cart-count {
            background: #d4af37;
            color: #0a0908;
            font-size: 0.7rem;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
        }
        .hamburger span {
            width: 25px;
            height: 2px;
            background: #ede4d3;
            transition: 0.3s;
        }

        /* Sidebar Cart */
        .cart-sidebar {
            position: fixed;
            top: 0;
            right: -100%;
            width: 400px;
            max-width: 90vw;
            height: 100vh;
            background: #161210;
            border-left: 1px solid rgba(212, 175, 55, 0.2);
            z-index: 1001;
            transition: right 0.4s ease;
            display: flex;
            flex-direction: column;
            box-shadow: -5px 0 30px rgba(0,0,0,0.5);
        }
        .cart-sidebar.open {
            right: 0;
        }
        .cart-header {
            padding: 24px;
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .cart-header h3 {
            font-size: 1.3rem;
            font-weight: 500;
        }
        .close-cart {
            background: none;
            border: none;
            color: #a8967a;
            font-size: 1.8rem;
            cursor: pointer;
        }
        .cart-items {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }
        .cart-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid rgba(212, 175, 55, 0.1);
        }
        .cart-item-info h4 {
            font-size: 1rem;
            margin-bottom: 4px;
        }
        .cart-item-info p {
            font-size: 0.8rem;
            color: #d4af37;
        }
        .cart-item-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .cart-item-actions button {
            background: rgba(212, 175, 55, 0.2);
            border: none;
            color: #d4af37;
            width: 28px;
            height: 28px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }
        .cart-item-actions span {
            min-width: 20px;
            text-align: center;
        }
        .cart-footer {
            padding: 20px;
            border-top: 1px solid rgba(212, 175, 55, 0.2);
        }
        .cart-total {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            font-size: 1.2rem;
            font-weight: bold;
        }
        .checkout-btn {
            width: 100%;
            background: #d4af37;
            color: #0a0908;
            border: none;
            padding: 14px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }
        .checkout-btn:hover {
            background: #e8cc6a;
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(212,175,55,0.08) 0%, #0a0908 80%);
            padding: 100px 20px;
        }
        .hero-content h1 {
            font-size: clamp(3rem, 10vw, 6rem);
            font-weight: 800;
            letter-spacing: 4px;
        }
        .hero-content h1 span {
            color: #d4af37;
        }
        .hero-content p {
            color: #a8967a;
            margin-top: 20px;
            font-size: 1.1rem;
        }
        .btn-group {
            margin-top: 40px;
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .btn {
            padding: 12px 32px;
            border: 1px solid #d4af37;
            background: transparent;
            color: #d4af37;
            cursor: pointer;
            transition: 0.3s;
            font-weight: 600;
        }
        .btn-primary {
            background: #d4af37;
            color: #0a0908;
            border: none;
        }
        .btn-primary:hover {
            background: #e8cc6a;
            transform: translateY(-2px);
        }
        .btn-outline:hover {
            background: rgba(212, 175, 55, 0.1);
        }

        /* Products Grid */
        .section {
            padding: 80px 48px;
            max-width: 1400px;
            margin: 0 auto;
        }
        .section-title {
            font-size: 2rem;
            margin-bottom: 48px;
            text-align: center;
        }
        .section-title em {
            color: #d4af37;
            font-style: normal;
        }
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2px;
            background: rgba(212, 175, 55, 0.15);
            border: 1px solid rgba(212, 175, 55, 0.1);
        }
        .product-card {
            background: #0d0b0a;
            padding: 28px 24px;
            transition: 0.3s;
            cursor: pointer;
        }
        .product-card:hover {
            background: #161210;
            transform: translateY(-4px);
        }
        .product-card h3 {
            font-size: 1.5rem;
            margin-bottom: 8px;
        }
        .product-price {
            color: #d4af37;
            font-size: 1.3rem;
            margin: 16px 0;
        }
        .product-price span {
            font-size: 0.8rem;
        }
        .add-to-cart {
            background: transparent;
            border: 1px solid #d4af37;
            color: #d4af37;
            padding: 8px 16px;
            cursor: pointer;
            transition: 0.3s;
            width: 100%;
        }
        .add-to-cart:hover {
            background: #d4af37;
            color: #0a0908;
        }

        /* Order Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }
        .modal-content {
            background: #161210;
            border: 1px solid #d4af37;
            max-width: 500px;
            width: 90%;
            padding: 30px;
            border-radius: 8px;
        }
        .modal-content input, .modal-content textarea {
            width: 100%;
            padding: 10px;
            margin: 12px 0;
            background: #0a0908;
            border: 1px solid #a8967a;
            color: #ede4d3;
        }
        .modal-content label {
            font-size: 0.9rem;
            color: #d4af37;
        }
        .qr-img {
            text-align: center;
            margin: 15px 0;
        }
        .qr-img img {
            width: 150px;
            background: white;
            padding: 10px;
        }
        .confirm-order {
            background: #d4af37;
            color: #0a0908;
            border: none;
            padding: 12px;
            width: 100%;
            font-weight: bold;
            margin-top: 16px;
            cursor: pointer;
        }

        footer {
            text-align: center;
            padding: 40px;
            border-top: 1px solid rgba(212, 175, 55, 0.2);
            color: #a8967a;
        }

        @media (max-width: 768px) {
            .navbar { padding: 16px 24px; }
            .nav-links { display: none; }
            .hamburger { display: flex; }
            .section { padding: 50px 20px; }
        }
    </style>
</head>
<body>

<div id="custom-cursor"></div>
<div id="cursor-dot"></div>

<!-- Navbar -->
<nav class="navbar" id="navbar">
    <a href="#" class="logo">
        <img class="logo-img" src="data:image/png;base64," alt="NOCTARA">
        <span class="logo-text"><span>N</span>OCTARA</span>
    </a>
    <div class="nav-links">
        <a href="#products">المنتجات</a>
        <a href="#about">عن NOCTARA</a>
        <a href="#contact">تواصل</a>
    </div>
    <button class="cart-icon" id="cartIconBtn">
        🛒 <span class="cart-count" id="cartCount">0</span>
    </button>
    <div class="hamburger" id="hamburger">
        <span></span><span></span><span></span>
    </div>
</nav>

<!-- Cart Sidebar -->
<div class="cart-sidebar" id="cartSidebar">
    <div class="cart-header">
        <h3>سلة المشتريات</h3>
        <button class="close-cart" id="closeCartBtn">&times;</button>
    </div>
    <div class="cart-items" id="cartItemsContainer">
        <div style="text-align:center; padding:40px;">سلة فارغة</div>
    </div>
    <div class="cart-footer">
        <div class="cart-total">
            <span>الإجمالي:</span>
            <span id="cartTotalAmount">0 ج.م</span>
        </div>
        <button class="checkout-btn" id="checkoutBtn">متابعة إلى الدفع</button>
    </div>
</div>

<!-- Hero -->
<section class="hero">
    <div class="hero-content">
        <h1>NOC<span>T</span>ARA</h1>
        <p>قهوة متخصصة بروح أدبية | 100% عربيكا</p>
        <div class="btn-group">
            <button class="btn btn-primary" onclick="document.getElementById('products').scrollIntoView({behavior:'smooth'})">تسوق الآن</button>
            <button class="btn btn-outline" onclick="document.getElementById('about').scrollIntoView({behavior:'smooth'})">قصتنا</button>
        </div>
    </div>
</section>

<!-- Products Section -->
<div id="products" class="section">
    <h2 class="section-title">ستة <em>سرود</em> في عربيكا</h2>
    <div class="products-grid" id="productsGrid">
        <!-- Products will be injected here -->
    </div>
</div>

<!-- About Section -->
<div id="about" class="section">
    <h2 class="section-title">لماذا <em>NOCTARA</em></h2>
    <div style="max-width: 800px; margin: 0 auto; text-align: center; line-height: 1.8;">
        <p>نحن براند مصري بروح أدبية، نؤمن بأن القهوة الجيدة تشبه الرواية الجيدة؛ تحتاج إلى عمق، صبر، وشغف. كل خلطة من خلطاتنا الست تحمل اسماً مستوحى من رحلة، وكل كوب يروي قصة.</p>
        <p style="margin-top: 30px; color: #d4af37; font-style: italic;">"الحقيقة، كما يعلم الجميع، لا تكون أبداً كما نتخيلها."</p>
    </div>
</div>

<!-- Contact -->
<div id="contact" class="section" style="text-align: center;">
    <h2 class="section-title">تواصل <em>معنا</em></h2>
    <div style="display: flex; gap: 20px; justify-content: center;">
        <a href="https://wa.me/201551290097" target="_blank" style="color:#d4af37;">📱 واتساب</a>
        <a href="#" style="color:#d4af37;">📷 إنستجرام</a>
    </div>
</div>

<footer>
    <p>© 2026 NOCTARA Coffee · القاهرة، مصر · جميع الحقوق محفوظة</p>
    <p style="font-size: 0.8rem; margin-top: 10px;">لمن يقرأ بطعم العمق</p>
</footer>

<!-- Modal for Checkout -->
<div id="checkoutModal" class="modal">
    <div class="modal-content">
        <h3 style="margin-bottom: 20px;">إتمام الطلب</h3>
        <div class="qr-img">
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=01551290097" alt="QR InstaPay">
            <p>رقم المحفظة: <strong style="direction: ltr; display: inline-block;">01551290097</strong> (InstaPay / محفظة)</p>
        </div>
        <label>📸 صورة الإيصال (Screenshot):</label>
        <input type="file" id="receiptImage" accept="image/*" capture="environment">
        <label>📍 العنوان الكامل:</label>
        <input type="text" id="address" placeholder="العنوان بالتفصيل">
        <label>📞 رقم الهاتف:</label>
        <input type="tel" id="phone" placeholder="مثال: 0123456789">
        <textarea id="orderNotes" rows="3" placeholder="ملاحظات إضافية (اختياري)"></textarea>
        <button class="confirm-order" id="confirmOrderBtn">تأكيد الطلب وإرسال</button>
        <button style="margin-top: 12px; background: none; border: 1px solid #a8967a; color:#a8967a; padding: 8px;" id="closeModalBtn">إغلاق</button>
    </div>
</div>

<script>
    // -------- PRODUCTS DATA ----------
    const products = [
        { id: 1, name: "Nomad — الرحالة", price: 280, description: "خلطة متوازنة مع هيل دافئ" },
        { id: 2, name: "Obsidian — أوبسيديان", price: 310, description: "تحميص داكن، دخان عميق" },
        { id: 3, name: "Aurora — الشفق", price: 300, description: "عسل وفاكهة الحجر، متوسط" },
        { id: 4, name: "Pearl — اللؤلؤ", price: 290, description: "خفيف، زهري، توت بري" },
        { id: 5, name: "Andes — الأنديز", price: 320, description: "شوكولاتة داكنة، أصل واحد" },
        { id: 6, name: "Amazon — الأمازون", price: 300, description: "جريء، ترابي، توابل" }
    ];

    // Cart State
    let cart = [];
    
    // Load cart from localStorage
    function loadCart() {
        const saved = localStorage.getItem('noctara_cart');
        if(saved) {
            cart = JSON.parse(saved);
        } else {
            cart = [];
        }
        updateCartUI();
    }
    
    function saveCart() {
        localStorage.setItem('noctara_cart', JSON.stringify(cart));
        updateCartUI();
    }
    
    function addToCart(product) {
        const existing = cart.find(item => item.id === product.id);
        if(existing) {
            existing.quantity += 1;
        } else {
            cart.push({ ...product, quantity: 1 });
        }
        saveCart();
        showToast("تمت إضافة المنتج إلى السلة ✅");
    }
    
    function updateQuantity(id, delta) {
        const idx = cart.findIndex(item => item.id === id);
        if(idx !== -1) {
            cart[idx].quantity += delta;
            if(cart[idx].quantity <= 0) {
                cart.splice(idx,1);
            }
            saveCart();
        }
    }
    
    function removeItem(id) {
        cart = cart.filter(item => item.id !== id);
        saveCart();
    }
    
    function updateCartUI() {
        const container = document.getElementById('cartItemsContainer');
        const countSpan = document.getElementById('cartCount');
        const totalSpan = document.getElementById('cartTotalAmount');
        
        let totalItems = 0;
        let totalPrice = 0;
        
        if(cart.length === 0) {
            container.innerHTML = '<div style="text-align:center; padding:40px;">سلة فارغة</div>';
            countSpan.innerText = '0';
            totalSpan.innerText = '0 ج.م';
            return;
        }
        
        let html = '';
        cart.forEach(item => {
            totalItems += item.quantity;
            totalPrice += item.price * item.quantity;
            html += `
                <div class="cart-item">
                    <div class="cart-item-info">
                        <h4>${item.name}</h4>
                        <p>${item.price} ج.م</p>
                    </div>
                    <div class="cart-item-actions">
                        <button onclick="updateQuantity(${item.id}, -1)">-</button>
                        <span>${item.quantity}</span>
                        <button onclick="updateQuantity(${item.id}, 1)">+</button>
                        <button onclick="removeItem(${item.id})" style="background:none; color:#a8967a;">🗑️</button>
                    </div>
                </div>
            `;
        });
        container.innerHTML = html;
        countSpan.innerText = totalItems;
        totalSpan.innerText = totalPrice + ' ج.م';
    }
    
    // Render Products
    function renderProducts() {
        const grid = document.getElementById('productsGrid');
        grid.innerHTML = products.map(p => `
            <div class="product-card">
                <h3>${p.name}</h3>
                <p style="color:#a8967a; margin:8px 0;">${p.description}</p>
                <div class="product-price"><span>ج.م</span> ${p.price}</div>
                <button class="add-to-cart" onclick="addToCart({id:${p.id}, name:'${p.name}', price:${p.price}})">➕ أضف إلى السلة</button>
            </div>
        `).join('');
    }
    
    // Toast message
    function showToast(msg) {
        let toast = document.getElementById('dynamicToast');
        if(!toast) {
            toast = document.createElement('div');
            toast.id = 'dynamicToast';
            toast.style.position = 'fixed';
            toast.style.bottom = '20px';
            toast.style.right = '20px';
            toast.style.backgroundColor = '#161210';
            toast.style.border = '1px solid #d4af37';
            toast.style.color = '#d4af37';
            toast.style.padding = '12px 24px';
            toast.style.zIndex = '9999';
            toast.style.fontSize = '0.9rem';
            document.body.appendChild(toast);
        }
        toast.textContent = msg;
        toast.style.opacity = '1';
        setTimeout(() => { toast.style.opacity = '0'; }, 2500);
    }
    
    // Checkout Logic
    function openCheckout() {
        if(cart.length === 0) {
            showToast("السلة فارغة! أضف منتجات أولاً.");
            return;
        }
        document.getElementById('checkoutModal').style.display = 'flex';
    }
    
    function closeModal() {
        document.getElementById('checkoutModal').style.display = 'none';
        document.getElementById('receiptImage').value = '';
        document.getElementById('address').value = '';
        document.getElementById('phone').value = '';
        document.getElementById('orderNotes').value = '';
    }
    
    function confirmOrder() {
        const address = document.getElementById('address').value.trim();
        const phone = document.getElementById('phone').value.trim();
        const receiptFile = document.getElementById('receiptImage').files[0];
        const notes = document.getElementById('orderNotes').value;
        
        if(!address || !phone) {
            showToast("الرجاء إدخال العنوان ورقم الهاتف");
            return;
        }
        if(!receiptFile) {
            showToast("الرجاء رفع صورة الإيصال");
            return;
        }
        
        // Prepare message for WhatsApp
        let orderDetails = "🛒 *طلب جديد من NOCTARA* 🛒\n\n";
        cart.forEach(item => {
            orderDetails += `• ${item.name} × ${item.quantity} = ${item.price * item.quantity} ج.م\n`;
        });
        const total = cart.reduce((sum,i)=> sum + (i.price * i.quantity),0);
        orderDetails += `\n💰 *الإجمالي:* ${total} ج.م`;
        orderDetails += `\n📍 *العنوان:* ${address}`;
        orderDetails += `\n📞 *الهاتف:* ${phone}`;
        if(notes) orderDetails += `\n📝 *ملاحظات:* ${notes}`;
        
        // Read receipt image as base64
        const reader = new FileReader();
        reader.onload = function(e) {
            const imageBase64 = e.target.result;
            const fullMsg = encodeURIComponent(orderDetails + `\n\n🖼️ *صورة الإيصال:* (مرفقة)`);
            // Open WhatsApp with pre-filled message and also attach image note
            window.open(`https://wa.me/201551290097?text=${fullMsg}`, '_blank');
            
            // Also send email (simulate)
            alert("✅ تم إرسال طلبك! سيتم التواصل معك قريباً للتأكيد.");
            // Clear cart after order
            cart = [];
            saveCart();
            closeModal();
        };
        reader.readAsDataURL(receiptFile);
    }
    
    // Event Listeners
    document.getElementById('cartIconBtn').addEventListener('click', () => {
        document.getElementById('cartSidebar').classList.add('open');
    });
    document.getElementById('closeCartBtn').addEventListener('click', () => {
        document.getElementById('cartSidebar').classList.remove('open');
    });
    document.getElementById('checkoutBtn').addEventListener('click', openCheckout);
    document.getElementById('closeModalBtn').addEventListener('click', closeModal);
    document.getElementById('confirmOrderBtn').addEventListener('click', confirmOrder);
    
    // Navbar scroll effect
    window.addEventListener('scroll', () => {
        document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 60);
    });
    
    // Cursor effect
    const cursor = document.getElementById('custom-cursor');
    const cursorDot = document.getElementById('cursor-dot');
    document.addEventListener('mousemove', (e) => {
        cursor.style.left = e.clientX + 'px';
        cursor.style.top = e.clientY + 'px';
        cursorDot.style.left = e.clientX + 'px';
        cursorDot.style.top = e.clientY + 'px';
    });
    
    // Mobile menu (simple)
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.querySelector('.nav-links');
    hamburger.addEventListener('click', () => {
        if(navLinks.style.display === 'flex') navLinks.style.display = 'none';
        else navLinks.style.display = 'flex';
    });
    window.addEventListener('resize', () => {
        if(window.innerWidth > 768) navLinks.style.display = 'flex';
        else navLinks.style.display = 'none';
    });
    
    // Initialize
    renderProducts();
    loadCart();
</script>
</body>
</html>
